        <mxCell id="1754" value="идентификация оборудования через RFID метку или QR, отсутствие необходимости предоставлять бумажные версии паспорта, РЭ, методики поверки" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#f08e81;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=0;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="740" y="640" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="1756" value="&lt;div style=&quot;language:en-GB;margin-top:0pt;margin-bottom:0pt;&lt;br/&gt;margin-left:.38in;text-indent:-.38in&quot; class=&quot;O0&quot;&gt;&lt;span style=&quot;font-size:10.0pt;&lt;br/&gt;language:ru&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;И&lt;/span&gt;&lt;span style=&quot;font-size:10.0pt;language:ru&quot;&gt;дентификация&lt;br&gt;оборудования по приложенным документам (РЭ, паспорт, методика поверки) перед поверкой&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#f08e81;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=0;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="40" y="640" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="1757" value="" style="edgeStyle=none;rounded=0;jumpStyle=none;html=1;shadow=0;labelBackgroundColor=none;startArrow=none;startFill=0;endArrow=classic;endFill=1;jettySize=auto;orthogonalLoop=1;strokeColor=#1699D3;strokeWidth=3;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;spacing=5;" parent="1" source="1760" target="1763" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="1759" value="" style="edgeStyle=none;rounded=0;jumpStyle=none;html=1;shadow=0;labelBackgroundColor=none;startArrow=none;startFill=0;endArrow=classic;endFill=1;jettySize=auto;orthogonalLoop=1;strokeColor=#1699D3;strokeWidth=3;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;spacing=5;" parent="1" source="1760" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="740" y="1150" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="1760" value="&lt;div style=&quot;language:en-GB;margin-top:0pt;margin-bottom:0pt;&lt;br/&gt;margin-left:.38in;text-indent:-.38in&quot; class=&quot;O0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Внесение данных в Аршин&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#1699d3;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=1;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="520" y="1020" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="1763" value="&lt;div style=&quot;language:en-GB;margin-top:0pt;margin-bottom:0pt;&lt;br/&gt;margin-left:.38in;text-indent:-.38in&quot; class=&quot;O0&quot;&gt;&lt;span style=&quot;font-size:10.0pt;&lt;br/&gt;language:ru&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;language:en-GB;margin-top:0pt;margin-bottom:0pt;&lt;br/&gt;margin-left:.38in;text-indent:-.38in&quot; class=&quot;O0&quot;&gt;&lt;span style=&quot;text-indent: -0.38in; background-color: initial; font-size: 10pt;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Поверитель&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;text-indent: -0.38in; background-color: initial; font-size: 10pt;&quot;&gt;вносит данные в аршин. Когда это произойдёт никто не знает и не&amp;nbsp;сообщает, даты внесения в Аршин в самом Аршине нет, но есть чёткие&amp;nbsp;законодательно установленные сроки на обновлении данных по СИ во ФГИС ФСА.&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;text-indent: -0.38in; background-color: initial; font-size: 10pt;&quot;&gt;Приходится постоянно проверять эти данные в Аршине вручную&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#64bbe2;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="40" y="1000" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="1764" value="&lt;p style=&quot;language:en-GB;margin-top:0pt;margin-bottom:0pt;margin-left:0in&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Заявка на поверку&lt;/font&gt;&lt;/p&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#F08705;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=1;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="520" y="120" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="1765" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;Выбор в базе лабораторного оборудования предприятия списка СИ для поверки, импорт данных о нём из ДЭП и формирование электронной заявки в соответствующие ЦСМ и ГНМЦ (с возможностью выбора в зависимости от их области аккредитации)" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#f5af58;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="740" y="100" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="1766" value="" style="edgeStyle=none;rounded=0;jumpStyle=none;html=1;shadow=0;labelBackgroundColor=none;startArrow=none;startFill=0;endArrow=classic;endFill=1;jettySize=auto;orthogonalLoop=1;strokeColor=#F08705;strokeWidth=3;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;spacing=5;" parent="1" source="1764" target="1765" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="1769" value="&lt;div style=&quot;margin-top: 0pt; margin-bottom: 0pt; text-indent: -0.38in;&quot; class=&quot;O0&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;margin-top: 0pt; margin-bottom: 0pt; text-indent: -0.38in;&quot; class=&quot;O0&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;&amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;У каждого ЦСМ и ГНМЦ своя форма заявки.&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;margin-top: 0pt; margin-bottom: 0pt; text-indent: -0.38in;&quot; class=&quot;O0&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Данные, которые каждый раз заполнятся вручную, как минимум: наименование, тип СИ, зав.&amp;nbsp;номер, год выпуска, тип поверки, № ГРСИ.&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;margin-top: 0pt; margin-bottom: 0pt; text-indent: -0.38in;&quot; class=&quot;O0&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Заявка бывает в бумажном или в&lt;br&gt;электронном виде&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#f5af58;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="40" y="100" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="1770" value="" style="edgeStyle=none;rounded=0;jumpStyle=none;html=1;shadow=0;labelBackgroundColor=none;startArrow=none;startFill=0;endArrow=classic;endFill=1;jettySize=auto;orthogonalLoop=1;strokeColor=#F08705;strokeWidth=3;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;spacing=5;" parent="1" source="1764" target="1769" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="1771" value="&lt;span style=&quot;text-indent: -36.48px;&quot;&gt;Подтверждение предлагаемых услуг со стороны заказчика и назначение даты поверки&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#12aab5;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=1;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="520" y="480" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="1772" value="&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Уведомление в личном кабинете о статусе заявки&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Согласование услуг и их стоимости в личном кабинете как со стороны исполнителя, так и со стороны заказчика.&lt;/font&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Выбор и согласование возможных дат и времени визита поверителя или запись в отдел приёмки для сдачи СИ на поверку&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#61c6ce;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=0;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="740" y="370" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="1773" value="" style="edgeStyle=none;rounded=1;jumpStyle=none;html=1;shadow=0;labelBackgroundColor=none;startArrow=none;startFill=0;jettySize=auto;orthogonalLoop=1;strokeColor=#12AAB5;strokeWidth=3;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;spacing=5;fontStyle=1;fillColor=#b0e3e6;" parent="1" source="1771" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="1778" value="&lt;div style=&quot;language:en-GB;margin-top:0pt;margin-bottom:0pt;&lt;br/&gt;margin-left:.38in;text-indent:-.38in&quot; class=&quot;O0&quot;&gt;&lt;div style=&quot;language:en-GB;margin-top:0pt;margin-bottom:0pt;&lt;br/&gt;margin-left:.38in;text-indent:-.38in&quot; class=&quot;O0&quot;&gt;&lt;span style=&quot;font-size:10.0pt;&lt;br/&gt;language:ru&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Оплата счёта по предоплате или подтверждение стоимости работы при&amp;nbsp;постоплате&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;language:en-GB;margin-top:0pt;margin-bottom:0pt;&lt;br/&gt;margin-left:.38in;text-indent:-.38in&quot; class=&quot;O0&quot;&gt;&lt;span style=&quot;font-size:10.0pt;&lt;br/&gt;language:ru&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Если поверка в лаборатории, то звонок по телефону для уточнения даты визита&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#61c6ce;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=0;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
          <mxGeometry x="40" y="460" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="1779" value="" style="edgeStyle=none;rounded=1;jumpStyle=none;html=1;shadow=0;labelBackgroundColor=none;startArrow=none;startFill=0;jettySize=auto;orthogonalLoop=1;strokeColor=#12AAB5;strokeWidth=3;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;spacing=5;fontStyle=1;fillColor=#b0e3e6;" parent="1" source="1771" target="1778" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cDaIsRxxzUIUzGIAj8a9-1779" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;Этапы поверки&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="570" y="40" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cDaIsRxxzUIUzGIAj8a9-1780" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;Сейчас&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;shadow=0;glass=0;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="210" y="40" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cDaIsRxxzUIUzGIAj8a9-1781" value="&lt;span style=&quot;font-size: 20px;&quot;&gt;ДЭП&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="900" y="40" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cDaIsRxxzUIUzGIAj8a9-1787" value="&lt;div style=&quot;margin-top: 0pt; margin-bottom: 0pt; text-indent: -0.38in; font-size: 14px;&quot; class=&quot;O0&quot;&gt;&lt;div style=&quot;margin-top: 0pt; margin-bottom: 0pt; text-indent: -0.38in;&quot; class=&quot;O0&quot;&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Отправка бумажной заявки по email не позволяет понять получена ли она ЦСМ или ГНМЦ. П&lt;span style=&quot;text-indent: -0.38in; background-color: initial;&quot;&gt;риходится держать в памяти, дублировать заявку или звонить,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;text-indent: -0.38in; background-color: initial;&quot;&gt;уточнять статус.&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;margin-top: 0pt; margin-bottom: 0pt; text-indent: -0.38in;&quot; class=&quot;O0&quot;&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Электронная&amp;nbsp; форма заявки в личных кабинетах есть&amp;nbsp;&lt;span style=&quot;text-indent: -36.48px; background-color: initial;&quot;&gt;не у всех&lt;/span&gt;&lt;span style=&quot;text-indent: -0.38in; background-color: initial;&quot;&gt;&amp;nbsp;ЦСМ/ГНМЦ и она не единая.&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#2F5B7C;fontFamily=Helvetica;fontSize=16;fontColor=#FFFFFF;align=center;fontStyle=1;spacing=5;arcSize=7;perimeterSpacing=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="cDaIsRxxzUIUzGIAj8a9-1788" value="" style="edgeStyle=none;rounded=0;jumpStyle=none;html=1;shadow=0;labelBackgroundColor=none;startArrow=none;startFill=0;endArrow=classic;endFill=1;jettySize=auto;orthogonalLoop=1;strokeColor=#2F5B7C;strokeWidth=3;fontFamily=Helvetica;fontSize=16;fontColor=#23445D;spacing=5;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="1749" target="cDaIsRxxzUIUzGIAj8a9-1787">
